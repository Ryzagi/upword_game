# Word Describer — environment template.
#
# Copy to `.env` on the server, fill in the real values, then bring the
# stack up:
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose --profile prod up -d --build
#
# Compose reads .env automatically; it never gets committed (see .gitignore).

# ---------------------------------------------------------------- Backend

# Log verbosity for uvicorn / app. DEBUG | INFO | WARNING | ERROR
APP_LOG_LEVEL=INFO

# JSON list of browser origins allowed to call the API directly. With Caddy
# fronting everything, the browser sees same-origin — this list mostly
# blocks API access from other sites.
APP_CORS_ORIGINS=["https://upword.live","https://www.upword.live"]

# Optional MyMemory contact email — raises the free translation quota from
# 1k → 10k characters per day. Leave blank to keep the lower quota.
APP_TRANSLATION_EMAIL=

# OpenAI — required for in-lobby AI theme generation. Leave blank to
# disable the feature (the UI will show "AI theme generation isn't
# enabled on this server" if anyone tries).
APP_OPENAI_API_KEY=
APP_OPENAI_MODEL=gpt-5.4-2026-03-05
APP_OPENAI_REASONING_EFFORT=medium
# Translator model. When APP_OPENAI_API_KEY is set, the in-game translate
# bar uses this instead of MyMemory. A nano-class model is the right
# trade-off for short single-word translations.
APP_OPENAI_TRANSLATION_MODEL=gpt-5.4-nano-2026-03-17

# Set to true only in test environments to short-circuit the translator
# with the noop stub. Production should always leave this unset / false.
# APP_TRANSLATOR_DISABLED=false

# ---------------------------------------------------------------- Caddy / TLS

# Real email that Let's Encrypt uses to notify you ~20 days before a cert
# expires if renewal ever fails. Strongly recommended in production.
CADDY_ACME_EMAIL=admin@upword.live

# ---------------------------------------------------------------- Compose

# Host port the frontend container publishes (dev profile only — Caddy
# binds 80/443 directly in the prod profile).
PUBLIC_PORT=8080
