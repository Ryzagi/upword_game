  "rules": {
    "title": "How to play",
    "kicker": "the rules in 6 bites",
    "signoff": "now go play!",
    "basics": {
      "heading": "The gist",
      "body": "One player describes a hidden word in their own words. Everyone else races to guess it. Solo or in teams. The describer rotates each round."
    },
    "board": {
      "heading": "The board",
      "body": "Pick a theme and difficulty from the grid. Harder cells pay more but are tougher to describe and guess."
    },
    "modes": {
      "heading": "Time vs attempts",
      "body": "Timed: a clock runs each round — guess freely until time's up. Attempts: you get N free guesses per round; extras cost 10 points."
    },
    "scoring": {
      "heading": "Scoring",
      "body": "First team to guess gets full points; each next team gets 20% less. Describer earns half of the round's points if anyone guesses. Concede = nobody scores."
    },
    "tools": {
      "heading": "Tools",
      "body": "👍/👎 the describer's style. The translation bar helps with tricky words across languages. Both reset each round."
    },
    "tips": {
      "heading": "Tips",
      "body": "Lead with category and shape (\"a kitchen tool, made of metal\"), then details. Never say the secret word. Stuck? Try a different angle, not louder."
    }
  },
